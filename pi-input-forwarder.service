[Unit]
Description=Pi KVM Bridge Internal Input Forwarder
After=pi-hid-server.service

[Service]
ExecStart=/usr/bin/python3 /opt/pi-kvm-bridge/pi_kvm_bridge/pi_input_forwarder.py
WorkingDirectory=/opt/pi-kvm-bridge/pi_kvm_bridge/
Restart=always
User=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target